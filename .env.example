# Server and Database Configuration (Configuração do Servidor e Banco de Dados)
PORT=3000

# Variáveis usadas apenas pelo perfil optional-db do docker-compose.yml (Postgres em Docker, porta 5433)
POSTGRES_USER=admin
POSTGRES_PASSWORD=sua_senha_aqui
POSTGRES_DB=alphatoca

# Postgres nativo (default). Para usar Docker, suba o perfil optional-db (porta 5433) — ver docker-compose.yml e README.
DATABASE_URL=postgresql://imoveis:sua_senha_aqui@127.0.0.1:5432/imoveis?schema=public
DIRECT_URL=postgresql://imoveis:sua_senha_aqui@127.0.0.1:5432/imoveis?schema=public

# Queue and Cache (Fila e Cache - Redis)
REDIS_URL=redis://127.0.0.1:6380

# Auth0 Configuration (Configuração de Login/Autenticação)
# Pegue esses dados em: https://manage.auth0.com (Applications > Your App)
AUTH0_AUDIENCE=https://alphatoca-api
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com/
AUTH0_CLIENT_ID=seu_client_id_aqui
AUTH0_CLIENT_SECRET=seu_client_secret_aqui

# Google AI Studio — Gemini 2.5 Flash (chat) + gemini-embedding-001 (embeddings, 1536 dims)
# Crie em: https://aistudio.google.com/apikey (sem cartão no free tier; 5 RPM free).
GOOGLE_API_KEY=

# LangSmith tracing (optional, for RAG observability in prod)
# Set LANGCHAIN_TRACING_V2=true to enable; all LLM/retriever calls will stream to LangSmith.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=alphatoca-dev
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com   # override only for self-hosted LangSmith

# WhatsApp Cloud API (Comunicação via WhatsApp)
# Configure um App no portal Meta for Developers: https://developers.facebook.com
TOKEN_ACCES_WHATSAPP=
PHONE_NUMBER_ID=
# Token usado pela Meta para verificar o webhook (GET /api/webhook). Defina algo aleatório e use o MESMO valor no painel da Meta.
WHATSAPP_VERIFY_TOKEN=
# App Secret da Meta (App Settings > Basic > App Secret). Usado para verificar o HMAC SHA-256 enviado no header X-Hub-Signature-256.
META_APP_SECRET=

# Firebase Admin SDK (Push Notifications)
# Configure um projeto no Firebase Console, vá em Project Settings > Service Accounts e gere uma nova chave privada.
FIREBASE_PROJECT_ID=alphatoca-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@alphatoca-dev.iam.gserviceaccount.com
# ATENÇÃO: No .env local coloque a sua chave inteira com os \n. No .env.example NÃO coloque a chave real!
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCOLOQUE_SUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"
# Firebase Web API Key (usada para login via REST API)
# Encontre em: Firebase Console > Project Settings > General > Web API Key
FIREBASE_API_KEY=sua_web_api_key_aqui

# Eval script — overrides opcionais (vazio = usa defaults de src/config/rag.ts)
# EVAL_SIMILARITY_THRESHOLD=0.55     # produção sugerida para Gemini embeddings em PT-BR
# EVAL_INTER_QUESTION_DELAY_MS=15000 # espaça chamadas para respeitar 5 RPM free tier

# Observability / logging
# LOG_LEVEL=info                     # trace | debug | info | warn | error | fatal | silent

# Rate limit por phoneNumber no worker (protege cota Gemini contra spam de 1 usuário)
# PHONE_RATE_LIMIT=10                # máx. mensagens por janela
# PHONE_RATE_WINDOW_SECONDS=60       # janela em segundos

# Worker / ingestion tuning
# LEAD_EXTRACTION_CONCURRENCY=3      # chamadas LLM simultâneas de extração de leads
# EMBEDDING_BATCH_SIZE=100           # tamanho do batch de embeddings no ingestKnowledge

# Frontend base URL para geracao de Deep Links de busca no WhatsApp
APP_BASE_URL=https://app.i-moveis.com

# Email (nodemailer) para envio de redefinição de senha e notificações
# Use Gmail SMTP com senha de app (https://myaccount.google.com/apppasswords)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=seu-email@gmail.com
# MAIL_PASS=xxxx xxxx xxxx xxxx
# MAIL_FROM=I-Moveis <seu-email@gmail.com>

# ==========================================
# Kafka Configuration (Message Broker)
# ==========================================
# Kafka brokers (comma-separated para cluster)
# Local: localhost:9092
# Cloud: use Confluent Cloud ou AWS MSK endpoints
KAFKA_BROKERS=localhost:9092

# Producer settings
KAFKA_PRODUCER_TIMEOUT=30000

# Consumer settings
KAFKA_CONSUMER_SESSION_TIMEOUT=20000
KAFKA_CONSUMER_HEARTBEAT_INTERVAL=3000

# ==========================================
# DEPRECATED - bullMQ (remover quando Kafka estiver 100% integrado)
# ==========================================
# REDIS_URL=redis://127.0.0.1:6380

# Feature flags de debug (branch hospedagem_local)
# DISABLE_WORKERS=false   # true desabilita BullMQ/Kafka workers em src/server.ts (debug local)
# DISABLE_RAG_VALIDATION=false   # true pula assertRagSecrets() — endpoints RAG podem falhar
