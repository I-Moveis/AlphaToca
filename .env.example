# Auth0 Configuration
AUTH0_AUDIENCE=https://your-api-identifier.com
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# Google AI Studio — Gemini 2.5 Flash (chat) + gemini-embedding-001 (embeddings, 1536 dims)
# Crie em: https://aistudio.google.com/apikey (sem cartão no free tier; 5 RPM free).
GOOGLE_API_KEY=

# LangSmith tracing (optional, for RAG observability in prod)
# Set LANGCHAIN_TRACING_V2=true to enable; all LLM/retriever calls will stream to LangSmith.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=alphatoca-dev
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com   # override only for self-hosted LangSmith

# Eval script — overrides opcionais (vazio = usa defaults de src/config/rag.ts)
# EVAL_SIMILARITY_THRESHOLD=0.55     # produção sugerida para Gemini embeddings em PT-BR
# EVAL_INTER_QUESTION_DELAY_MS=15000 # espaça chamadas para respeitar 5 RPM free tier
