# Server and Database Configuration (Configuração do Servidor e Banco de Dados)
PORT=3000

# Local Database (Banco de Dados Local - Docker)
POSTGRES_USER=admin
POSTGRES_PASSWORD=sua_senha_aqui
POSTGRES_DB=alphatoca

# Database Connection URL (URL de Conexão com o Banco)
# Substitua 'sua_senha_aqui' pela senha definida acima.
DATABASE_URL=postgresql://admin:sua_senha_aqui@127.0.0.1:5444/alphatoca?schema=public

# Queue and Cache (Fila e Cache - Redis)
REDIS_URL=redis://127.0.0.1:6380

# Auth0 Configuration (Configuração de Login/Autenticação)
# Pegue esses dados em: https://manage.auth0.com (Applications > Your App)
AUTH0_AUDIENCE=https://alphatoca-api
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com/
AUTH0_CLIENT_ID=seu_client_id_aqui
AUTH0_CLIENT_SECRET=seu_client_secret_aqui

# Google AI Studio — Gemini 2.5 Flash (chat) + gemini-embedding-001 (embeddings, 1536 dims)
# Crie em: https://aistudio.google.com/apikey (sem cartão no free tier; 5 RPM free).
GOOGLE_API_KEY=

# LangSmith tracing (optional, for RAG observability in prod)
# Set LANGCHAIN_TRACING_V2=true to enable; all LLM/retriever calls will stream to LangSmith.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=alphatoca-dev
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com   # override only for self-hosted LangSmith

# WhatsApp Cloud API (Comunicação via WhatsApp)
# Configure um App no portal Meta for Developers: https://developers.facebook.com
TOKEN_ACCES_WHATSAPP=
PHONE_NUMBER_ID=
# Token usado pela Meta para verificar o webhook (GET /api/webhook). Defina algo aleatório e use o MESMO valor no painel da Meta.
WHATSAPP_VERIFY_TOKEN=
# App Secret da Meta (App Settings > Basic > App Secret). Usado para verificar o HMAC SHA-256 enviado no header X-Hub-Signature-256.
META_APP_SECRET=

# Eval script — overrides opcionais (vazio = usa defaults de src/config/rag.ts)
# EVAL_SIMILARITY_THRESHOLD=0.55     # produção sugerida para Gemini embeddings em PT-BR
# EVAL_INTER_QUESTION_DELAY_MS=15000 # espaça chamadas para respeitar 5 RPM free tier
