    "pino-pretty": "^13.1.3",
    "prisma": "6.4.1",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2",
