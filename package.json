    "@langchain/openai": "^1.4.5",
    "@langchain/textsplitters": "^1.0.1",
    "@prisma/client": "6.4.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/redis-emitter": "^5.1.0",
    "axios": "^1.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.0",
    "firebase-admin": "^13.8.0",
    "ioredis": "^5.10.1",
    "kafkajs": "^2.2.4",
    "langchain": "^1.3.3",
    "langsmith": "^0.5.19",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
