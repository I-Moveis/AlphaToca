    "kafka:health": "ts-node scripts/kafka-health-check.ts",
    "kafka:test": "ts-node scripts/kafka-message-test.ts",
    "kafka:topics": "ts-node scripts/create-kafka-topics.ts",
    "verify:env": "ts-node scripts/verify-environment.ts"
  },
  "dependencies": {
