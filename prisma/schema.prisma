// 1. Configuração do Banco e Gerador
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"] // Necessário para o pgvector
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector] // Habilita a extensão vetorial no Postgres
}

// 2. Enums (Restrições de Valores)
enum Role {
  TENANT
  LANDLORD
  ADMIN
}

enum PropertyStatus {
  AVAILABLE
  NEGOTIATING
  RENTED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChatStatus {
  ACTIVE_BOT
  WAITING_HUMAN
  RESOLVED
}

enum SenderType {
  BOT
  TENANT
  LANDLORD
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  CONDO_HOUSE
  KITNET
  PENTHOUSE
  LAND
  COMMERCIAL
}

enum ProcessStatus {
  TRIAGE
  VISIT_SCHEDULED
  CONTRACT_ANALYSIS
  CLOSED
}

enum DocumentType {
  IDENTITY
  INCOME_PROOF
  CONTRACT
}

enum VisitStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum VisitSource {
  MANUAL
  AI
}

enum MessageStatus {
  failed
  sent
  delivered
  read
}

enum NotificationType {
  VISIT_SCHEDULED
  VISIT_CANCELLED
  VISIT_REMINDER
  VISIT_COMPLETED
  RENTAL_STAGE_CHANGED
  RENTAL_CLOSED
  DOCUMENT_REQUESTED
  DOCUMENT_REJECTED
  PROPERTY_APPROVED
  PROPERTY_REJECTED
  BROADCAST
}

// US-013: cross-device notification history category. Distinct from
// NotificationType (which is the FCM-dispatch taxonomy — VISIT_*, DOCUMENT_*,
// BROADCAST, etc.). NotificationCategory is the coarser bucket the client uses
// to colour-code/group the /notifications screen: `update` = app updates,
// `announcement` = admin broadcasts, `system` = internal system events.
enum NotificationCategory {
  update
  announcement
  system
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTER_OFFER
  WITHDRAWN
}

// Status mensal de pagamento de aluguel por imóvel (modelo RentalPayment).
// Intencionalmente separado de `PaymentStatus` (PENDING|PAID|OVERDUE|CANCELLED),
// que pertence ao modelo `TenantPayment` do ciclo de Contract. O PRD pede o nome
// `PaymentStatus`, mas como Prisma não permite enums homônimos no mesmo schema,
// o nome foi prefixado para refletir o dono real da relação.
enum RentalPaymentStatus {
  AWAITING
  PAID
  LATE
}

// 3. Modelos (Tabelas)

model User {
  id          String   @id @default(uuid())
  firebaseUid String?  @unique @map("firebase_uid")
  name        String
  email       String?  @unique
  phoneNumber String   @unique @map("phone_number")
  role        Role     @default(TENANT)
  fcmToken    String?  @map("fcm_token")
  createdAt   DateTime @default(now()) @map("created_at")
  // LL-017 — "selo verificado" de identidade do tenant. Exibido como ✓ dourado
  // na ficha do inquilino. Read-only pela API neste epic: writable somente via
  // Prisma Studio/seed enquanto o endpoint admin (PRD §8 Q3) não é lançado.
  isIdentityVerified  Boolean   @default(false) @map("is_identity_verified")
  identityVerifiedAt  DateTime? @map("identity_verified_at")

  // Relacionamentos inversos (Obrigações do Prisma)
  properties          Property[]      @relation("LandlordProperties")
  chatSessions        ChatSession[]   @relation("TenantChats")
  rentalProcesses     RentalProcess[] @relation("TenantProcesses")
  visitsAsTenant      Visit[]         @relation("TenantVisits")
  visitsAsLandlord    Visit[]         @relation("LandlordVisits")
  notifications       Notification[]
  proposalsMade       Proposal[]      @relation("TenantProposals")
  favorites           Favorite[]      @relation("UserFavorites")
  contractsAsTenant   Contract[]      @relation("TenantContracts")
  contractsAsLandlord Contract[]      @relation("LandlordContracts")
  rentalPaymentUpdates RentalPayment[] @relation("RentalPaymentUpdatedBy")
  conversationsAsLandlord Conversation[] @relation("LandlordConversations")
  conversationsAsTenant   Conversation[] @relation("TenantConversations")
  supportTicketsOpened    SupportTicket[] @relation("SupportTicketOpener")
  supportTicketsAssigned  SupportTicket[] @relation("SupportTicketAssignee")
  supportTicketMessages   SupportTicketMessage[] @relation("SupportMessageSender")
  profileViewsReceived    ProfileView[]   @relation("LandlordProfileViews")

  @@map("users")
}

model Property {
  id               String           @id @default(uuid())
  landlordId       String           @map("landlord_id")
  title            String
  description      String
  price            Decimal          @db.Decimal(10, 2)
  status           PropertyStatus   @default(AVAILABLE)
  moderationStatus ModerationStatus @default(PENDING) @map("moderation_status")
  moderationReason String?          @map("moderation_reason")
  moderatedAt      DateTime?        @map("moderated_at")
  moderatedBy      String?          @map("moderated_by")
  address          String
  city             String?
  state            String?          @db.VarChar(2)
  zipCode          String?          @map("zip_code")

  // Novos campos para busca e filtros
  type         PropertyType @default(APARTMENT)
  bedrooms     Int          @default(0)
  bathrooms    Int          @default(0)
  parkingSpots Int          @default(0) @map("parking_spots")
  area         Float        @default(0)
  isFurnished  Boolean      @default(false) @map("is_furnished")
  petsAllowed  Boolean      @default(false) @map("pets_allowed")
  hasWifi      Boolean      @default(false) @map("has_wifi")
  hasPool      Boolean      @default(false) @map("has_pool")
  latitude     Float?
  longitude    Float?
  nearSubway   Boolean      @default(false) @map("near_subway")
  isFeatured   Boolean      @default(false) @map("is_featured")
  views        Int          @default(0)
  createdAt    DateTime     @default(now()) @map("created_at")
  condoFee     Decimal?     @map("condo_fee") @db.Decimal(10, 2)
  propertyTax  Decimal?     @map("property_tax") @db.Decimal(10, 2)

  // Relacionamentos
  landlord        User              @relation("LandlordProperties", fields: [landlordId], references: [id])
  rentalProcesses RentalProcess[]
  images          PropertyImage[]
  visits          Visit[]
  proposals       Proposal[]
  favoritedBy     Favorite[]
  contracts       Contract[]
  expenses        PropertyExpense[]
  maintenanceLogs MaintenanceLog[]
  rentalPayments  RentalPayment[]
  conversations   Conversation[]
  chatSessions    ChatSession[]
  viewEvents      PropertyViewEvent[] @relation("PropertyViewEvents")
  contactClickEvents ContactClickEvent[] @relation("PropertyContactClickEvents")

  @@index([moderationStatus], name: "properties_moderation_status_idx")
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  url        String // URL da imagem no storage (ex: S3, Cloudinary)
  isCover    Boolean  @default(false) @map("is_cover") // Identifica se é a foto de capa
  caption    String? // Descrição do ambiente (ex: "Sala de Estar")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relacionamentos
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model ChatSession {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  propertyId String?    @map("property_id")
  status     ChatStatus @default(ACTIVE_BOT)
  startedAt  DateTime   @default(now()) @map("started_at")
  // TTL da sessão. Após este instante, o worker cria uma nova sessão ACTIVE_BOT
  // em vez de reutilizar esta (evita arrastar histórico obsoleto de semanas atrás).
  expiresAt  DateTime   @default(dbgenerated("(now() + interval '7 days')")) @map("expires_at")

  // Relacionamentos
  tenant   User      @relation("TenantChats", fields: [tenantId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])
  messages Message[]

  @@index([expiresAt], name: "chat_sessions_expires_at_idx")
  @@index([propertyId], name: "chat_sessions_property_id_idx")
  @@map("chat_sessions")
}

model Message {
  id         String        @id @default(uuid())
  wamid      String?       @unique @map("wamid")
  sessionId  String        @map("session_id")
  senderType SenderType    @map("sender_type")
  content    String        @db.Text
  mediaUrl   String?       @map("media_url")
  status     MessageStatus @default(sent) @map("status")
  timestamp  DateTime      @default(now())

  // Relacionamentos
  session ChatSession @relation(fields: [sessionId], references: [id])

  @@map("messages")
}

model RentalProcess {
  id         String        @id @default(uuid())
  tenantId   String        @map("tenant_id")
  propertyId String?       @map("property_id") // Pode ser nulo durante a triagem
  status     ProcessStatus @default(TRIAGE)
  createdAt  DateTime      @default(now()) @map("created_at")

  // Relacionamentos
  tenant    User                 @relation("TenantProcesses", fields: [tenantId], references: [id])
  property  Property?            @relation(fields: [propertyId], references: [id])
  insights  AiExtractedInsight[]
  documents RentalDocument[]
  visits    Visit[]

  @@map("rental_processes")
}

model AiExtractedInsight {
  id              String   @id @default(uuid())
  rentalProcessId String   @map("rental_process_id")
  insightKey      String   @map("insight_key")
  insightValue    String   @map("insight_value")
  extractedAt     DateTime @default(now()) @map("extracted_at")

  // Relacionamentos
  rentalProcess RentalProcess @relation(fields: [rentalProcessId], references: [id])

  @@map("ai_extracted_insights")
}

model KnowledgeDocument {
  id          String                       @id @default(uuid())
  title       String
  content     String                       @db.Text
  // Vetor de embeddings gerado pelo LangChain (Google gemini-embedding-001 @ 1536 dims).
  // Gemini usa MRL; 1536 entrega a mesma pontuação de 3072 em benchmarks oficiais.
  // Embeddings com dims < 3072 exigem normalização L2 no cliente antes de indexar.
  embedding   Unsupported("vector(1536)")?
  sourcePath  String                       @map("source_path")
  chunkIndex  Int                          @map("chunk_index")
  contentHash String                       @map("content_hash")
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")

  @@unique([sourcePath, chunkIndex], name: "knowledge_documents_source_chunk_key")
  @@index([contentHash], name: "knowledge_documents_content_hash_idx")
  @@map("knowledge_documents")
}

model RentalDocument {
  id              String       @id @default(uuid())
  rentalProcessId String       @map("rental_process_id")
  documentType    DocumentType @map("document_type")
  fileUrl         String       @map("file_url")

  // Relacionamentos
  rentalProcess RentalProcess @relation(fields: [rentalProcessId], references: [id])

  @@map("rental_documents")
}

// Persistência de payloads de webhook que falharam validação ou processamento.
// Usada para investigação posterior sem precisar escanear logs agregados.
model WebhookFailure {
  id        String   @id @default(uuid())
  source    String // Ex.: "whatsapp". Futuro: "stripe", "mercadopago", etc.
  rawBody   Json     @map("raw_body")
  headers   Json?
  error     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  reviewed  Boolean  @default(false)

  @@index([source, reviewed, createdAt], name: "webhook_failures_triage_idx")
  @@map("webhook_failures")
}

model Visit {
  id              String      @id @default(uuid())
  propertyId      String      @map("property_id")
  tenantId        String      @map("tenant_id")
  // landlordId é denormalizado (copiado de Property.landlordId no momento da
  // criação) para permitir detecção de conflito de agenda por locador em uma
  // única query sem JOIN. Se o dono da Property mudar depois, visitas antigas
  // mantêm o landlord original — isto é intencional (registro histórico).
  landlordId      String      @map("landlord_id")
  rentalProcessId String?     @map("rental_process_id")
  scheduledAt     DateTime    @map("scheduled_at")
  durationMinutes Int         @default(45) @map("duration_minutes")
  status          VisitStatus @default(SCHEDULED)
  source          VisitSource @default(MANUAL)
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  property      Property       @relation(fields: [propertyId], references: [id])
  tenant        User           @relation("TenantVisits", fields: [tenantId], references: [id])
  landlord      User           @relation("LandlordVisits", fields: [landlordId], references: [id])
  rentalProcess RentalProcess? @relation(fields: [rentalProcessId], references: [id])

  @@index([propertyId, scheduledAt], name: "visits_property_time_idx")
  @@index([landlordId, scheduledAt], name: "visits_landlord_time_idx")
  @@map("visits")
}

model Notification {
  id         String               @id @default(uuid())
  userId     String               @map("user_id")
  type       NotificationType
  category   NotificationCategory @default(announcement)
  title      String
  body       String
  data       Json? // Payload extra (visitId, propertyId, etc.)
  readAt     DateTime?            @map("read_at") // null = não lida
  receivedAt DateTime             @default(now()) @map("received_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt], name: "notifications_user_read_idx")
  @@index([userId, receivedAt], name: "notifications_user_received_at_idx")
  @@map("notifications")
}

model Proposal {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  propertyId    String         @map("property_id")
  proposedPrice Decimal        @map("proposed_price") @db.Decimal(10, 2)
  status        ProposalStatus @default(PENDING)
  message       String?        @db.Text
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  tenant   User     @relation("TenantProposals", fields: [tenantId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId], name: "proposals_property_idx")
  @@index([tenantId], name: "proposals_tenant_idx")
  @@map("proposals")
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  propertyId String   @map("property_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId], name: "favorites_user_property_key")
  @@index([userId], name: "favorites_user_idx")
  @@map("favorites")
}

model PropertyExpense {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  type       String // "IPTU", "CONDO", "INSURANCE", etc.
  amount     Decimal  @db.Decimal(10, 2)
  dueDate    DateTime @map("due_date")
  isPaid     Boolean  @default(false) @map("is_paid")
  year       Int
  month      Int
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, year, month])
  @@map("property_expenses")
}

model MaintenanceLog {
  id          String   @id @default(uuid())
  propertyId  String   @map("property_id")
  title       String
  description String?  @db.Text
  cost        Decimal? @db.Decimal(10, 2)
  date        DateTime
  status      String   @default("COMPLETED") // "PLANNED", "IN_PROGRESS", "COMPLETED"
  createdAt   DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("maintenance_logs")
}

// O modelo Contract é a fonte de verdade do "ciclo ativo de locação" neste
// codebase — ver progress.txt US-004/US-005. O PRD US-013 oferecia (A) estender
// RentalProcess ou (B) criar um novo Contract; como o Contract já existia com
// startDate/endDate/monthlyRent/landlordId/tenantId, a decisão foi estender
// este modelo com os campos que faltavam para o ciclo digital (`pdfUrl` renomeado
// a partir de `contractUrl`, `signedAt` novo), sem criar um modelo paralelo.
model Contract {
  id          String         @id @default(uuid())
  propertyId  String         @map("property_id")
  tenantId    String         @map("tenant_id")
  landlordId  String         @map("landlord_id")
  startDate   DateTime       @map("start_date")
  endDate     DateTime       @map("end_date")
  monthlyRent Decimal        @map("monthly_rent") @db.Decimal(10, 2)
  dueDay      Int            @map("due_day")
  // URL do PDF do contrato (antigo `contractUrl` — renomeado em US-013 para
  // casar com o contrato exposto na API). Populado pelo PUT
  // /api/contracts/:id/signed-document (US-016).
  pdfUrl      String?        @map("pdf_url")
  // Marca o momento em que o landlord fez upload do PDF assinado. Setado pelo
  // PUT /api/contracts/:id/signed-document (US-016). `null` enquanto não há
  // versão assinada armazenada.
  signedAt    DateTime?      @map("signed_at")
  status      ContractStatus @default(ACTIVE)
  // Estado documental da locação, exposto como chip na tela "Meus Inquilinos"
  // do landlord (LL-016). Contratos com `signed_at IS NOT NULL` são
  // backfilled para APPROVED; demais contratos partem do default
  // PENDING_DOCUMENTS. O flip para AWAITING_SIGNATURE/APPROVED é feito via
  // PATCH /api/contracts/:id/document-status.
  documentStatus ContractDocumentStatus @default(PENDING_DOCUMENTS) @map("document_status")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  property Property        @relation(fields: [propertyId], references: [id])
  tenant   User            @relation("TenantContracts", fields: [tenantId], references: [id])
  landlord User            @relation("LandlordContracts", fields: [landlordId], references: [id])
  payments TenantPayment[]

  @@map("contracts")
}

enum ContractStatus {
  ACTIVE
  TERMINATED
  COMPLETED
}

// Estado documental do contrato (LL-016). Alimenta o chip de status documental
// na tela "Meus Inquilinos" do landlord, independente de Contract.status.
enum ContractDocumentStatus {
  PENDING_DOCUMENTS
  AWAITING_SIGNATURE
  APPROVED
}

model TenantPayment {
  id         String        @id @default(uuid())
  contractId String        @map("contract_id")
  amount     Decimal       @db.Decimal(10, 2)
  dueDate    DateTime      @map("due_date")
  paidDate   DateTime?     @map("paid_date")
  status     PaymentStatus @default(PENDING)
  createdAt  DateTime      @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id])

  @@map("tenant_payments")
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// Registro mensal de status do aluguel por (propertyId, period="YYYY-MM").
// Usado pelos endpoints GET/PUT /api/properties/:id/payments/current (US-009, US-010).
// Quando não há linha para o mês corrente, a API responde com o default (AWAITING)
// sem persistir — a inserção ocorre apenas quando o landlord escreve via PUT (upsert).
model RentalPayment {
  id         String              @id @default(uuid())
  propertyId String              @map("property_id")
  period     String              @db.VarChar(7) // formato 'YYYY-MM'
  status     RentalPaymentStatus @default(AWAITING)
  // Valor do aluguel do mês, em BRL. Gravado no upsert a partir do
  // Contract.monthlyRent ativo no momento. Nullable: a coluna foi adicionada
  // após linhas já existirem e só é backfilled best-effort (ver migration
  // header). Mantendo nullable também cobre o caso de imóvel sem contrato
  // ativo no momento do write (LL-003).
  amount     Decimal?            @db.Decimal(10, 2)
  updatedAt  DateTime            @updatedAt @map("updated_at")
  updatedBy  String?             @map("updated_by")

  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  updatedByUser User?    @relation("RentalPaymentUpdatedBy", fields: [updatedBy], references: [id])

  @@unique([propertyId, period], name: "rental_payments_property_period_key")
  @@index([propertyId], name: "rental_payments_property_idx")
  @@map("rental_payments")
}

// Tickets de suporte abertos por usuários finais (landlord/tenant) ou por admins,
// listados e triados via endpoints /api/support/tickets (US-018) e
// /api/admin/support/tickets (US-019/US-020). `code` é um protocolo humano
// SUP-AAMMDD-XXXX gerado no POST; `userRole` captura o role no momento da
// abertura para auditoria (mesmo que o role do usuário mude depois).
enum SupportUserRole {
  TENANT
  LANDLORD
  ADMIN
}

enum SupportTicketStatus {
  OPEN
  RESOLVED
}

model SupportTicket {
  id           String              @id @default(uuid())
  code         String              @unique
  title        String
  description  String              @db.Text
  userId       String              @map("user_id")
  userName     String              @map("user_name")
  userRole     SupportUserRole     @map("user_role")
  status       SupportTicketStatus @default(OPEN)
  resolution   String?             @db.Text
  assignedToId String?             @map("assigned_to_id")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  user       User  @relation("SupportTicketOpener", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("SupportTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   SupportTicketMessage[] @relation("TicketMessages")

  @@index([status, createdAt], name: "support_tickets_status_created_idx")
  @@index([userRole, createdAt], name: "support_tickets_role_created_idx")
  @@index([userId], name: "support_tickets_user_idx")
  @@map("support_tickets")
}

// Mensagens trocadas dentro de um ticket de suporte entre o opener
// (tenant/landlord) e o admin. Cada mensagem é associada a um ticket
// e a um usuário remetente. Ordenação por timestamp ASC na listagem.
model SupportTicketMessage {
  id         String          @id @default(uuid())
  ticketId   String          @map("ticket_id")
  senderId   String          @map("sender_id")
  senderRole SupportUserRole @map("sender_role")
  content    String          @db.Text
  timestamp  DateTime        @default(now())

  ticket SupportTicket @relation("TicketMessages", fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation("SupportMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId, timestamp])
  @@map("support_ticket_messages")
}

// Thread de chat canônico entre um (landlord, tenant) em torno de um Property.
// O id é referência estável usada pelo frontend (substitui os antigos ids sintéticos
// "property-<pid>-tenant-<tid>"). O endpoint GET /api/conversations/resolve (US-012)
// faz upsert na chave composta (propertyId, landlordId, tenantId) — a unicidade é
// o mecanismo anti-race. Mensagens vivem em outra tabela (fora do escopo deste PRD);
// a API documenta `messages: []` como placeholder.
model Conversation {
  id            String    @id @default(uuid())
  propertyId    String    @map("property_id")
  landlordId    String    @map("landlord_id")
  tenantId      String    @map("tenant_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastMessageAt DateTime? @map("last_message_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  landlord User     @relation("LandlordConversations", fields: [landlordId], references: [id], onDelete: Cascade)
  tenant   User     @relation("TenantConversations", fields: [tenantId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@unique([propertyId, landlordId, tenantId], name: "conversations_property_landlord_tenant_key")
  @@index([landlordId], name: "conversations_landlord_idx")
  @@index([tenantId], name: "conversations_tenant_idx")
  @@map("conversations")
}

// Mensagens do canal in-app entre landlord e tenant (epic LL — chat).
// Kept distinct from `messages(session_id)` because that table services the
// WhatsApp/RAG ChatSession flow; fusing would force nullable FKs and confuse
// the RAG worker (src/workers/*). LL-011/LL-012/LL-013 expose list/messages/post.
model ConversationMessage {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  authorId       String    @map("author_id")
  content        String    @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  readAt         DateTime? @map("read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt], name: "conversation_messages_conversation_created_idx")
  @@index([conversationId, readAt], name: "conversation_messages_conversation_read_idx")
  @@map("conversation_messages")
}

// Registro de aberturas do perfil público de um landlord. Usado pelo card
// "Visitas ao perfil" do dashboard (GET /api/landlord/metrics, LL-002) que
// conta linhas dos últimos 30 dias. `viewerId` é nulo para visitantes anônimos;
// quando não nulo, o service aplica dedup de 24h (LL-001) para não inflar o
// contador com F5 do mesmo usuário logado.
model ProfileView {
  id         String   @id @default(uuid())
  landlordId String   @map("landlord_id")
  viewerId   String?  @map("viewer_id")
  viewedAt   DateTime @default(now()) @map("viewed_at")

  landlord User @relation("LandlordProfileViews", fields: [landlordId], references: [id], onDelete: Cascade)

  @@index([landlordId, viewedAt], name: "profile_views_landlord_time_idx")
  @@map("profile_views")
}

// Evento por abertura da ficha de um Property. Alimenta a série diária do
// endpoint de analytics por imóvel (LL-008 GET /api/properties/:id/analytics) —
// `views` em Property.views (contador agregado all-time) continua sendo
// incrementado em paralelo para preservar o ordering `orderBy=views` no
// search existente. `viewerId` é nulo para visitantes anônimos; quando
// não nulo, o service aplica dedup de 1h (LL-006) — mais curto que o dedup
// de ProfileView (24h) porque a granularidade do gráfico é diária.
model PropertyViewEvent {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  viewerId   String?  @map("viewer_id")
  viewedAt   DateTime @default(now()) @map("viewed_at")

  property Property @relation("PropertyViewEvents", fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, viewedAt], name: "property_view_events_property_time_idx")
  @@map("property_view_events")
}

// Evento de clique em "Contatar" na ficha de um Property. Alimenta o campo
// `contactClicks` do endpoint de analytics por imóvel (LL-008). `viewerId` é
// nulo para visitantes anônimos — o endpoint que registra o evento (POST
// /api/properties/:id/contact-click) é PUBLIC, então sempre pode receber
// cliques sem autenticação. Sem dedup: analytics de cliques conta CADA
// intenção de contato, não usuários únicos.
model ContactClickEvent {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  viewerId   String?  @map("viewer_id")
  clickedAt  DateTime @default(now()) @map("clicked_at")

  property Property @relation("PropertyContactClickEvents", fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, clickedAt], name: "contact_click_events_property_time_idx")
  @@map("contact_click_events")
}
